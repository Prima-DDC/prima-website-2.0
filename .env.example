# Public site URL (used for canonical URLs, hreflang, sitemap)
NEXT_PUBLIC_SITE_URL=https://www.primaddc.com

# Supabase project
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets (never expose with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (used only by scripts/db-migrate.mjs)
SUPABASE_DB_URL=

# Workspace notification emails (best-effort; in-app notifications always work)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
